#!/usr/bin/env bash
# claude-bus: file-based mailbox for cross-Claude-session messaging.
#
# One inbox directory per session under $CLAUDE_BUS_ROOT (default ~/.cache/claude-bus).
# SHORT messages only: send refuses bodies over $CLAUDE_BUS_MAX bytes (default 1024).
# Pass anything large (files, long output) BY PATH via send-path, not inline.
#
# send      -> atomically drops a SHORT message into the peer's inbox (write tmp + mv).
# send-path -> drops a pointer to a file (validates it exists); the body stays on disk.
# wait      -> blocks on the inbox dir via entr(-d); exits when a new message lands.
#              Run this with run_in_background so the harness re-invokes on arrival.
# drain     -> prints and deletes all queued messages, oldest first.
#
# Model loop:  drain <me>  ->  wait <me> (background)  -> [re-invoked] -> repeat.
#
# `set -euo pipefail` lives in main(), not at file scope, so the file can be
# sourced by tests without flipping shell options. The cmd_* functions guard
# their own inputs and do not rely on -e for correctness.

# Default under ~/.cache (XDG cache), not /tmp: /tmp is tmpfs and is wiped on
# reboot, which both splits the bus (a session that misses an explicit override
# falls back here) and loses all inbox state; ~/.cache persists it across reboots.
BUS_ROOT="${CLAUDE_BUS_ROOT:-${XDG_CACHE_HOME:-$HOME/.cache}/claude-bus}"
BUS_MAX="${CLAUDE_BUS_MAX:-1024}"   # max message body in bytes; bigger -> pass by path

inbox_dir() { printf '%s/inbox/%s' "$BUS_ROOT" "$1"; }
pending_dir() { printf '%s/pending/%s' "$BUS_ROOT" "$1"; }
meta_file() { printf '%s/meta/%s.json' "$BUS_ROOT" "$1"; }
delegate_file() { printf '%s/delegate/%s' "$BUS_ROOT" "$1"; }
# delegate_target <inbox> -- the name that drains <inbox>'s mail, or nothing.
# Must return 0 even when undelegated: `dt="$(delegate_target ...)"` under set -e
# would otherwise abort publish on every ordinary send.
delegate_target() { local df; df="$(delegate_file "$1")"; [ -f "$df" ] && head -n1 "$df"; return 0; }
log_dir() { printf '%s/log/%s' "$BUS_ROOT" "$1"; }
watch_dir() { printf '%s/watch/%s' "$BUS_ROOT" "$1"; }
watch_file() { printf '%s/watch/%s/%s.json' "$BUS_ROOT" "$1" "$2"; }
# oldest_msg <name> -- basename of the oldest undrained *.msg in <name>'s inbox, or
# nothing. Ids are ns-prefixed and equal-width, so lexicographic min == chronological.
oldest_msg() {
  local dir; dir="$(inbox_dir "$1")"
  local f best=""
  for f in "$dir"/*.msg; do
    [ -e "$f" ] || continue
    f="$(basename -- "$f")"
    if [ -z "$best" ] || [[ "$f" < "$best" ]]; then best="$f"; fi
  done
  printf '%s' "$best"
}

# the caller's own cgroup path (CLAUDE_BUS_SELF_CGROUP overrides, for tests).
self_cgroup() {
  if [ -n "${CLAUDE_BUS_SELF_CGROUP:-}" ]; then printf '%s' "$CLAUDE_BUS_SELF_CGROUP"
  else awk -F: '$1=="0"{print $3}' /proc/self/cgroup 2>/dev/null; fi
}

write_meta() {  # <name> <cgroup> <pid> <transcript>
  local md; md="$(dirname "$(meta_file "$1")")"; mkdir -p "$md"
  local tmp; tmp="$(meta_file "$1").tmp.$$"
  # Atomic + self-reporting: the redirect creates tmp before jq runs, so an
  # &&-chain is required — otherwise a jq that dies mid-write still leaves a
  # movable 0-byte tmp and the mv would rename corrupt meta into place and "succeed".
  jq -n --arg name "$1" --arg cgroup "$2" --arg pid "$3" --arg transcript "$4" \
    '{name:$name, cgroup:$cgroup, pid:$pid, transcript:$transcript}' > "$tmp" \
    && mv -- "$tmp" "$(meta_file "$1")" || { rm -f -- "$tmp"; return 1; }
}

# names are simple tokens, ids are digits/hyphens -- both block path traversal out
# of the bus root. The *_ok predicates are non-fatal (for validating untrusted
# envelope fields on drain); valid_* exit for CLI-arg validation.
name_ok() { case "$1" in '' | *[!A-Za-z0-9_-]*) return 1 ;; esac; return 0; }
id_ok()   { case "$1" in '' | *[!0-9-]*)        return 1 ;; esac; return 0; }
valid_name() { name_ok "$1" || { printf 'claude-bus: invalid name: %s\n' "$1" >&2; exit 7; }; }
valid_id()   { id_ok "$1"   || { printf 'claude-bus: invalid id: %s\n'   "$1" >&2; exit 7; }; }

# id = nanosecond timestamp + random tiebreaker, so same-ns sends never collide.
gen_id() { printf '%s-%s' "$(date +%s%N)" "$RANDOM$RANDOM"; }

# refuse bodies over the cap (send, dispatch, reply all call this).
check_size() {
  local nbytes; nbytes="$(printf '%s' "$1" | wc -c)"
  if (( nbytes > BUS_MAX )); then
    printf 'refused: message is %d bytes (max %d). Use send-path.\n' "$nbytes" "$BUS_MAX" >&2
    exit 3
  fi
}

# progressive disclosure: one-line guidance to stderr so stdout stays parseable.
tip() { printf 'next: %s\n' "$*" >&2; }

# publish <peer> <from> <kind> <id> <ref> <body>  -- atomic JSON file-drop into
# inbox. id is unique per message; ref is the task/expectation it correlates to (or "").
publish() {
  local peer="$1" from="$2" kind="$3" id="$4" ref="$5" body="$6"
  valid_name "$peer"; valid_name "$from"
  # Delegation: deliver into the delegate's inbox, but keep `to` as the original
  # peer so senders and the envelope are unchanged and the delegate sees intent.
  local deliver="$peer" dt
  dt="$(delegate_target "$peer")"
  [ -n "$dt" ] && name_ok "$dt" && deliver="$dt"
  local dir; dir="$(inbox_dir "$deliver")"
  mkdir -p "$dir"
  local tmp="$dir/.tmp.${id}.$$"
  local final="$dir/${id}.from-${from}.msg"
  jq -n --arg from "$from" --arg to "$peer" --arg id "$id" --arg ref "$ref" \
    --arg kind "$kind" --arg body "$body" \
    '{from:$from, to:$to, ts:$id, id:$id, ref:$ref, kind:$kind, body:$body}' > "$tmp"
  mv -- "$tmp" "$final"   # atomic publish: reader never sees a partial file
}

cmd_init() {
  local me="${1:?usage: claude-bus init <me>}"
  valid_name "$me"
  local dir; dir="$(inbox_dir "$me")"
  mkdir -p "$dir"
  : > "$dir/.keep"
  printf 'inbox ready: %s\n' "$dir"
  # Self-register for liveness, but only when we sit in a dedicated scope/service
  # cgroup. Registering the shared user slice would make the monitor read the
  # session as immortal, so skip it there and say so.
  local cg; cg="$(self_cgroup)"
  case "$cg" in
    *.scope | *.service)
      # Merge: explicit --cgroup refreshes THIS process's own scope (so a reused
      # name never keeps a dead prior session's scope), while the transcript still
      # inherits, so a launcher-set one is not blanked. Suppress register's success
      # chatter, but surface a real failure loudly (init runs at session startup).
      local rerr
      if rerr="$(cmd_register "$me" --cgroup "$cg" 2>&1 >/dev/null)"; then
        tip "registered for liveness; background 'claude-bus wait $me', drain when it wakes"
      else
        printf 'init: self-register failed: %s\n' "$rerr" >&2
        tip "background 'claude-bus wait $me', drain when it wakes (liveness registration failed)"
      fi ;;
    *)
      tip "background 'claude-bus wait $me', drain when it wakes (no scope cgroup: not monitorable)" ;;
  esac
}

# register <me> [--cgroup PATH] [--pid PID] [--transcript PATH] [--supervisor NAME]
# -- map a bus name to the process tree the monitor probes. Called by the launch
# wrapper at spawn (--cgroup from the container, --transcript once the session
# writes it), or self-invoked (auto-detects its own scope cgroup). Fields MERGE:
# a flag not passed inherits the prior meta, so the launcher and the agent can
# each register the half they know without clobbering the other's.
cmd_register() {
  local me="${1:?usage: claude-bus register <me> [--cgroup P] [--pid N] [--transcript P] [--supervisor NAME]}"; shift
  valid_name "$me"
  local cgroup="" pid="" transcript="" supervisor="" role=""
  local set_cgroup="" set_pid="" set_transcript=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --cgroup|--pid|--transcript|--supervisor|--role)
        [ $# -ge 2 ] || { printf 'register: %s needs a value\n' "$1" >&2; exit 2; }
        case "$1" in
          --cgroup)     cgroup="$2";     set_cgroup=1 ;;
          --pid)        pid="$2";        set_pid=1 ;;
          --transcript) transcript="$2"; set_transcript=1 ;;
          --supervisor) supervisor="$2" ;;
          --role)       role="$2" ;;
        esac
        shift 2 ;;
      *) printf 'register: unknown flag %s\n' "$1" >&2; exit 2 ;;
    esac
  done
  # An explicitly empty value means "inherit", not "clear" (a launcher passing an
  # unset $CG must not blank a correct field); un-mark it so the merge inherits.
  [ -n "$cgroup" ]     || set_cgroup=""
  [ -n "$pid" ]        || set_pid=""
  [ -n "$transcript" ] || set_transcript=""
  # --role is validated whenever given (a typo fails fast even without --supervisor);
  # a --supervisor auto-watch is erroring-only by default (role=ephemeral: a worker
  # dying is its normal terminal state, so the death is silent), and --role supervisor
  # opts a long-lived agent into the death-alarm.
  [ -z "$role" ] || case "$role" in supervisor|ephemeral) ;; *) printf 'register: --role must be supervisor or ephemeral\n' >&2; exit 5;; esac
  local dmax="${CLAUDE_BUS_DRAIN_MAX:-2}"
  if [ -n "$supervisor" ]; then
    valid_name "$supervisor"
    case "$dmax" in ''|*[!0-9]*) printf 'register: drain_max must be a non-negative integer\n' >&2; exit 5;; esac
    role="${role:-ephemeral}"
  fi
  # Merge + self-detect fallback, serialized so a launcher/agent race can't lose a
  # field. An unpassed field inherits the prior value; cgroup self-detects only
  # when still empty, so it never overwrites a launcher-set (correct) cgroup.
  # Explicit failure check (not set -e): a caller may invoke register in a context
  # where errexit is ignored (init runs it in an `if` condition), so the meta write
  # must propagate its own non-zero rather than relying on the shell to abort.
  # Capture at statement level, NOT `if ! (...)`: bash reports a redirection failure
  # on a compound command as exit 0 when it is an if-condition, so a `.lock` that
  # can't be opened would slip through; `|| wrc=$?` sees the real non-zero.
  local mf md wrc=0; mf="$(meta_file "$me")"; md="$(dirname "$mf")"; mkdir -p "$md"
  ( flock 9
    if [ -f "$mf" ]; then
      [ -n "$set_cgroup" ]     || cgroup="$(jq -r '.cgroup // ""'     "$mf" 2>/dev/null)" || cgroup=""
      [ -n "$set_pid" ]        || pid="$(jq -r '.pid // ""'           "$mf" 2>/dev/null)" || pid=""
      [ -n "$set_transcript" ] || transcript="$(jq -r '.transcript // ""' "$mf" 2>/dev/null)" || transcript=""
    fi
    [ -n "$cgroup" ] || cgroup="$(self_cgroup)"
    write_meta "$me" "$cgroup" "$pid" "$transcript"
  ) 9>"$md/.lock" || wrc=$?
  if [ "$wrc" -ne 0 ]; then
    printf 'register: failed to write meta for %s\n' "$me" >&2
    exit 1
  fi
  printf 'registered %s\n' "$me"
  tip "a peer can now 'claude-bus dispatch $me <from> <task>' and the monitor can probe it"
  # --supervisor auto-wires the parent's watch of this agent, so an ephemeral
  # worker is watched at spawn without the parent hand-wiring each one. Create-
  # if-absent: a re-register (the merge's second call) never resets a live record.
  if [ -n "$supervisor" ] && [ "$supervisor" != "$me" ]; then
    local swd; swd="$(watch_dir "$supervisor")"; mkdir -p "$swd"
    local swf; swf="$(watch_file "$supervisor" "$me")"
    ( flock 9; [ -e "$swf" ] || write_watch_record "$supervisor" "$me" "$dmax" "$role" ) 9>"$swd/.lock" || true
    if [ -e "$swf" ]; then tip "$supervisor now watches $me; background 'claude-bus monitor $supervisor' so its alerts land"; fi
  fi
}

# delegate <inbox> <to> -- mail addressed to <inbox> is delivered into <to>'s
# inbox instead (transparent interception; senders are unchanged). Per-name, so
# many coordinator/secretary pairs coexist with nothing hardcoded.
cmd_delegate() {
  local inbox="${1:?usage: claude-bus delegate <inbox> <to>}"
  local to="${2:?usage: claude-bus delegate <inbox> <to>}"
  valid_name "$inbox"; valid_name "$to"
  local df; df="$(delegate_file "$inbox")"; mkdir -p "$(dirname "$df")"
  printf '%s\n' "$to" > "$df"
  printf 'delegated %s -> %s\n' "$inbox" "$to"
  tip "mail to $inbox now lands in $to's inbox; already-running senders need no change"
}

cmd_undelegate() {
  local inbox="${1:?usage: claude-bus undelegate <inbox>}"
  valid_name "$inbox"
  rm -f -- "$(delegate_file "$inbox")"
  printf 'undelegated %s\n' "$inbox"
}

# write_watch_record <parent> <target> <dmax> <role> -- caller holds the parent's
# watch-dir lock. Atomic (tmp+mv) so a torn write can't leave an empty record
# (which would pin the monitor open). Shared by cmd_watch and register's
# --supervisor auto-watch so the record schema stays in one place. <role> is
# supervisor (death alarms) or ephemeral (death is a normal exit: silent + GC).
write_watch_record() {
  local wf; wf="$(watch_file "$1" "$2")"
  jq -n --arg t "$2" --argjson d "$3" --arg r "$4" '{target:$t,drain_max:$d,role:$r,last:"",ticks:0}' > "$wf.tmp.$$" \
    && mv -- "$wf.tmp.$$" "$wf" || { rm -f -- "$wf.tmp.$$"; return 1; }
}

# watch <me> <target> -- have <me>'s monitor flag <target> when it stops draining
# its inbox (rate-limited, hung, dead). Unlike dispatch's expectations, this needs
# no reply and no probe: a persistent sink (a secretary, an oncall) holds no
# expectation about itself, so its freeze is otherwise invisible.
cmd_watch() {
  local me="${1:?usage: claude-bus watch <me> <target>}"
  local target="${2:?usage: claude-bus watch <me> <target>}"
  valid_name "$me"; valid_name "$target"
  local dmax="${3:-${CLAUDE_BUS_DRAIN_MAX:-2}}"
  case "$dmax" in ''|*[!0-9]*) printf 'watch: drain_max must be a non-negative integer\n' >&2; exit 5;; esac
  local wd; wd="$(watch_dir "$me")"; mkdir -p "$wd"
  # Write atomically under the same lock unwatch and the tick take, so a torn or
  # racing write can't leave an empty record (which would pin the monitor open).
  local wf; wf="$(watch_file "$me" "$target")"
  ( flock 9; write_watch_record "$me" "$target" "$dmax" supervisor ) 9>"$wd/.lock" \
    || { rm -f -- "$wf.tmp.$$"; printf 'watch: failed to write %s\n' "$wf" >&2; exit 1; }
  printf 'watching %s for %s\n' "$target" "$me"
  tip "background 'claude-bus monitor $me'; a 'stale' alert lands in $me's inbox if $target stops draining"
}

cmd_unwatch() {
  local me="${1:?usage: claude-bus unwatch <me> <target>}"
  local target="${2:?usage: claude-bus unwatch <me> <target>}"
  valid_name "$me"; valid_name "$target"
  # Remove under the same lock the tick's read-modify-write takes, or an in-flight
  # tick could recreate the record we just deleted (as cmd_close does for pending).
  local wd; wd="$(watch_dir "$me")"; mkdir -p "$wd"
  ( flock 9; rm -f -- "$(watch_file "$me" "$target")"; ) 9>"$wd/.lock" || true
  printf 'unwatched %s for %s\n' "$target" "$me"
}

# forward <me> <id> <to> [note] -- re-send a message <me> already drained to <to>
# verbatim, with a provenance line and the forwarder's note, so an escalation is
# the agent's exact words plus a classification, not a paraphrase. Looks the
# original up in <me>'s drained-message log.
cmd_forward() {
  local me="${1:?usage: claude-bus forward <me> <id> <to> [note]}"; shift
  local id="${1:?usage: claude-bus forward <me> <id> <to> [note]}"; shift
  local to="${1:?usage: claude-bus forward <me> <id> <to> [note]}"; shift
  valid_name "$me"; valid_id "$id"; valid_name "$to"
  local note="$*"; check_size "$note"   # the composite may reach ~2x BUS_MAX by design
  local src="" f
  for f in "$(log_dir "$me")/$id".from-*.msg; do [ -e "$f" ] && { src="$f"; break; }; done
  [ -n "$src" ] || { printf 'forward: no drained message %s in %s log\n' "$id" "$me" >&2; exit 6; }
  local ofrom okind obody
  ofrom="$(jq -r '.from' "$src")"; okind="$(jq -r '.kind' "$src")"; obody="$(jq -r '.body' "$src")"
  local body; body="$(printf '%s\n--- forwarded from %s [%s %s] ---\n%s' "$note" "$ofrom" "$okind" "$id" "$obody")"
  publish "$to" "$me" forward "$(gen_id)" "" "$body"
  printf 'forwarded %s -> %s\n' "$id" "$to"
  tip "$to sees it verbatim via 'claude-bus drain $to'"
}

cmd_send() {
  local peer="${1:?usage: claude-bus send <peer> <from> <msg...>}"; shift
  local from="${1:?usage: claude-bus send <peer> <from> <msg...>}"; shift
  valid_name "$peer"; valid_name "$from"
  local body="$*"; check_size "$body"
  local id; id="$(gen_id)"
  publish "$peer" "$from" msg "$id" "" "$body"
  printf 'sent %s -> %s\n' "$id" "$peer"
  tip "peer reads + auto-acks via 'claude-bus drain $peer'; their ack lands in '$from'"
}

# send-path <peer> <from> <path> [note...] -- send a pointer to a file, not its contents.
cmd_send_path() {
  local peer="${1:?usage: claude-bus send-path <peer> <from> <path> [note...]}"; shift
  local from="${1:?usage: claude-bus send-path <peer> <from> <path> [note...]}"; shift
  local path="${1:?usage: claude-bus send-path <peer> <from> <path> [note...]}"; shift
  valid_name "$peer"; valid_name "$from"
  local note="$*"; check_size "$note"
  local abs
  if ! abs="$(realpath -e -- "$path" 2>/dev/null)"; then
    printf 'refused: path not found or unreadable: %s\n' "$path" >&2
    exit 4
  fi
  local id; id="$(gen_id)"
  publish "$peer" "$from" path "$id" "" "$(printf '[path] %s\nnote: %s' "$abs" "$note")"
  printf 'sent %s -> %s\n' "$id" "$peer"
  tip "peer reads it via 'claude-bus drain $peer'"
}

cmd_drain() {
  local me="${1:?usage: claude-bus drain <me>}"
  valid_name "$me"
  local dir; dir="$(inbox_dir "$me")"
  mkdir -p "$dir"
  # Drained messages are archived (not deleted) into a per-mailbox log (latest at
  # the canonical name, prior same-id versions as numbered backups), so `forward`
  # can re-send the verbatim original and out-of-band messages stay visible.
  # (Unbounded; GC is a follow-up.)
  local ld; ld="$(log_dir "$me")"; mkdir -p "$ld"
  # No `shopt -s nullglob` (it would leak into a sourcing caller); `had` is set
  # only after the [ -e ] guard so an empty inbox still prints "(no messages)".
  local f had=0 got=0 from kind id body to ref rseg adt adeliver
  for f in "$dir"/*.msg; do
    [ -e "$f" ] || continue
    had=1
    if ! jq empty "$f" 2>/dev/null; then
      printf 'warn: quarantining malformed envelope %s\n' "$f" >&2
      mv -- "$f" "$f.bad" 2>/dev/null || rm -f -- "$f"
      continue
    fi
    from="$(jq -r '.from // ""' "$f")"; kind="$(jq -r '.kind // ""' "$f")"
    id="$(jq -r '.id // ""' "$f")";     body="$(jq -r '.body // ""' "$f")"
    to="$(jq -r '.to // ""' "$f")";     ref="$(jq -r '.ref // ""' "$f")"
    # A well-formed envelope with a hostile/missing from/id/to must not reach
    # publish/rm/resolve (valid_name would exit 7 and wedge). Quarantine like malformed.
    if ! name_ok "$from" || ! id_ok "$id" || ! name_ok "$to"; then
      printf 'warn: quarantining envelope with bad from/id %s\n' "$f" >&2
      mv -- "$f" "$f.bad" 2>/dev/null || rm -f -- "$f"
      continue
    fi
    rseg=""; [ -n "$ref" ] && rseg=" ref:$ref"
    printf '===== %s [%s]%s from %s =====\n%s\n===== end =====\n' "$id" "$kind" "$rseg" "$from" "$body"
    # Resolve against the envelope's 'to' (the orchestrator): equals $me directly,
    # but is the real orchestrator when a delegate (secretary) drained this reply.
    case "$kind" in
      msg | path)
        # Warn (but still ack) when the ack would loop back into my own inbox: this
        # happens when the sender delegates here, so I'd be acking myself. Delivering
        # anyway keeps any expectation the ack resolves intact.
        adt="$(delegate_target "$from")"; adeliver="$from"
        [ -n "$adt" ] && name_ok "$adt" && adeliver="$adt"
        [ "$adeliver" = "$me" ] && printf 'note: auto-ack to %s loops back to %s (delegated here); delivering anyway\n' "$from" "$me" >&2
        publish "$from" "$me" ack "$(gen_id)" "$id" ""; got=1 ;;
      ack)        if id_ok "$ref"; then resolve_pending "$to" "$ref" acked; fi ;;
      done)       if id_ok "$ref"; then resolve_pending "$to" "$ref" close; fi ;;
      decision)   if id_ok "$ref"; then resolve_pending "$to" "$ref" awaiting; fi ;;
      progress)   : ;;
    esac
    # Message ids are unique, so archive names don't normally collide; --backup is a
    # defensive guard against any id reuse (a stray backup is .~N~, ignored by
    # *.msg globs, so forward still matches the one canonical file).
    mv --backup=numbered -- "$f" "$ld/$(basename -- "$f")"
  done
  [ "$had" -eq 0 ] && printf '(no messages)\n'
  [ "$had" -eq 1 ] && tip "re-arm: background 'claude-bus wait $me' to catch the next"
  [ "$got" -eq 1 ] && tip "to answer a task: 'claude-bus reply <orch> $me <id> done|decision <msg>'"
  return 0
}

# --- liveness probe: out-of-process signal readers (the imperative shell) ---
cg_base() { printf '%s%s' "${CLAUDE_BUS_SYSFS:-/sys/fs/cgroup}" "$1"; }

# All three readers walk the whole cgroup SUBTREE, not just the named node. In
# cgroup v2 a scope that has child cgroups (a coat/bwrap agent's podman leaf, or a
# nested systemd-run) holds no processes of its own, so reading only the top node's
# cgroup.procs would see it empty and false-fire "dead" every tick. `find` avoids
# `shopt -s globstar`, which would leak into a caller that sources this file.
# NOTE: cgroup.procs is a kernfs file, so `stat`/`[ -s ]` always report size 0;
# emptiness must be tested by reading content, not by file size.
tree_alive() {  # <cgroup> -> exit 0 if any leaf in the tree has a live process
  [ -n "$1" ] || return 1
  local b; b="$(cg_base "$1")"; [ -d "$b" ] || return 1
  local f
  while IFS= read -r f; do
    [ -n "$(head -c1 "$f" 2>/dev/null)" ] && return 0
  done < <(find "$b" -name cgroup.procs 2>/dev/null)
  return 1
}

tree_net() {    # <cgroup> -> summed bytes_acked across the subtree's tcp sockets
  [ -n "$1" ] || { echo 0; return; }
  local b; b="$(cg_base "$1")"; [ -d "$b" ] || { echo 0; return; }
  local f pids all=""
  while IFS= read -r f; do
    pids="$(tr '\n' '|' 2>/dev/null < "$f" | sed 's/|$//')" || pids=""
    [ -n "$pids" ] && all="${all:+$all|}$pids"
  done < <(find "$b" -name cgroup.procs 2>/dev/null)
  [ -n "$all" ] || { echo 0; return; }
  local sum
  sum="$(ss -tinp 2>/dev/null | grep -E "pid=(${all})," -A1 \
    | grep -oE 'bytes_acked:[0-9]+' | awk -F: '{s+=$2} END{print s+0}')" || true
  echo "${sum:-0}"
}

tree_oom() {    # <cgroup> -> oom_kill count (0 if unknown)
  # Unlike cgroup.procs (per-cgroup, hence the subtree walk in the readers above),
  # memory.events is hierarchical by default since Linux 5.2: a scope's own oom_kill
  # already aggregates its children's, so the top node is the correct, non-double-
  # counting read.
  local b v; b="$(cg_base "$1")"
  v="$(awk '/^oom_kill /{print $2; exit}' "$b/memory.events" 2>/dev/null)" || v=""
  echo "${v:-0}"
}

trans_mtime() { stat -c %Y "$1" 2>/dev/null || echo 0; }

probe_snapshot() {  # <name> -> {alive,net,oom,mtime,known}
  local name="$1" mf; valid_name "$name"; mf="$(meta_file "$name")"
  if [ ! -f "$mf" ]; then echo '{"alive":0,"net":0,"oom":0,"mtime":0,"known":false}'; return; fi
  local cg tr; cg="$(jq -r '.cgroup // ""' "$mf")"; tr="$(jq -r '.transcript // ""' "$mf")"
  local alive=0; if tree_alive "$cg"; then alive=1; fi
  jq -n --argjson alive "$alive" --argjson net "$(tree_net "$cg")" \
    --argjson oom "$(tree_oom "$cg")" --argjson mtime "$(trans_mtime "$tr")" \
    '{alive:$alive, net:$net, oom:$oom, mtime:$mtime, known:true}'
}

# classify <baseline-json> <current-json> -> working|retrying|idle|dead|oom|unknown.
# Pure (the functional core). dead and oom take precedence; then transcript growth
# is working, else network growth is retrying (talking but not producing, e.g. a
# 429/529 backoff), else idle.
classify() {
  local b="$1" c="$2"
  [ "$(jq -r '.known' <<<"$c")" = "false" ] && { echo unknown; return; }
  { [ "$b" = "null" ] || [ -z "$b" ]; } && { echo unknown; return; }
  [ "$(jq -r '.alive' <<<"$c")" = "0" ] && { echo dead; return; }
  local bo co; bo="$(jq -r '.oom' <<<"$b")"; co="$(jq -r '.oom' <<<"$c")"
  (( co > bo )) && { echo oom; return; }
  local bn cn bm cm
  bn="$(jq -r '.net' <<<"$b")"; cn="$(jq -r '.net' <<<"$c")"
  bm="$(jq -r '.mtime' <<<"$b")"; cm="$(jq -r '.mtime' <<<"$c")"
  if   (( cm > bm )); then echo working
  elif (( cn > bn )); then echo retrying
  else echo idle
  fi
}

# dispatch <peer> <from> <msg...> -- send a tracked task, opening a pending entry.
cmd_dispatch() {
  local peer="${1:?usage: claude-bus dispatch <peer> <from> <msg...>}"; shift
  local from="${1:?usage: claude-bus dispatch <peer> <from> <msg...>}"; shift
  valid_name "$peer"; valid_name "$from"
  local body="$*"; check_size "$body"
  local id; id="$(gen_id)"
  publish "$peer" "$from" msg "$id" "$id" "$body"
  local pd; pd="$(pending_dir "$from")"; mkdir -p "$pd"
  local base='null'
  [ -f "$(meta_file "$peer")" ] && base="$(probe_snapshot "$peer")"
  local tmp="$pd/.tmp.$id.$$"
  jq -n --arg peer "$peer" --arg id "$id" --arg state sent --argjson baseline "$base" \
    '{peer:$peer, id:$id, sent_ts:$id, state:$state, baseline:$baseline, flat:0, alerted:false, ticks:0}' > "$tmp"
  mv -- "$tmp" "$pd/$id.json"
  printf '%s\n' "$id"
  tip "tracking as $id; 'claude-bus pending $from' to watch; worker acks then replies when done"
}

cmd_pending() {
  local me="${1:?usage: claude-bus pending <me>}"
  valid_name "$me"
  local pd; pd="$(pending_dir "$me")"; mkdir -p "$pd"
  local f had=0
  for f in "$pd"/*.json; do
    [ -e "$f" ] || continue
    had=1; jq -r '"\(.id) \(.peer) \(.state)"' "$f"
  done
  [ "$had" -eq 0 ] && printf '(no open expectations)\n'
  [ "$had" -eq 1 ] && tip "awaiting the worker(s); they ack on receipt and reply when done"
  return 0
}

# resolve_pending <me> <id> <acked|awaiting|close>. The single-drainer invariant
# (one drain at a time per inbox) is what lets this skip file locking.
resolve_pending() {
  local me="$1" id="$2" action="$3"
  local pd; pd="$(pending_dir "$me")"; local pf="$pd/$id.json"
  [ -f "$pf" ] || return 0
  # Serialize with the monitor's read-modify-write (concurrent by design).
  (
    flock 9
    [ -f "$pf" ] || exit 0
    local tmp="$pf.tmp.$$"
    case "$action" in
      acked)    if jq '.state="acked"'         "$pf" > "$tmp" 2>/dev/null; then mv -- "$tmp" "$pf"; else rm -f -- "$tmp"; fi ;;
      awaiting) if jq '.state="awaiting_orch"' "$pf" > "$tmp" 2>/dev/null; then mv -- "$tmp" "$pf"; else rm -f -- "$tmp"; fi ;;
      close)    rm -f -- "$pf" ;;
    esac
  ) 9>"$pd/.lock" || true
}

# reply <orch> <from> <id> <kind> <msg...> -- worker sends progress/done/decision.
cmd_reply() {
  local peer="${1:?usage: claude-bus reply <orch> <from> <id> <kind> <msg...>}"; shift
  local from="${1:?usage: claude-bus reply <orch> <from> <id> <kind> <msg...>}"; shift
  local ref="${1:?usage: claude-bus reply <orch> <from> <id> <kind> <msg...>}"; shift
  local kind="${1:?usage: claude-bus reply <orch> <from> <id> <kind> <msg...>}"; shift
  valid_name "$peer"; valid_name "$from"; valid_id "$ref"
  case "$kind" in progress | done | decision) ;; *) printf 'bad kind: %s\n' "$kind" >&2; exit 5 ;; esac
  local body="$*"; check_size "$body"
  # unique message id; the caller's id is the task correlation (ref).
  publish "$peer" "$from" "$kind" "$(gen_id)" "$ref" "$body"
  printf 'replied %s -> %s\n' "$ref" "$peer"
  tip "orch sees it on 'claude-bus drain $peer'"
}

# close <me> <id> -- resolve an awaiting_orch expectation or GC a stale one.
cmd_close() {
  local me="${1:?usage: claude-bus close <me> <id>}"
  valid_name "$me"
  local id="${2:?usage: claude-bus close <me> <id>}"; valid_id "$id"
  local pd; pd="$(pending_dir "$me")"; mkdir -p "$pd"
  ( flock 9; rm -f -- "$pd/$id.json"; ) 9>"$pd/.lock" || true
  tip "expectation $id closed"
}

# monitor_tick <orch> -- one pass over open expectations; send only unliveness to
# the orchestrator's inbox, once per expectation. awaiting_orch is skipped (the
# ball is with the orchestrator); a null baseline (unregistered peer) is skipped.
cmd_monitor_tick() {
  local orch="$1"; valid_name "$orch"
  local pd; pd="$(pending_dir "$orch")"
  local wd; wd="$(watch_dir "$orch")"
  local flat_max="${CLAUDE_BUS_FLAT_MAX:-2}"
  local ack_max="${CLAUDE_BUS_ACK_MAX:-2}"
  # No `shopt -s nullglob`: it would leak into a caller that sources this file.
  # Guard the literal-glob case explicitly instead.
  local pf rec state baseline peer id flat ticks cur verdict unlive prev do_alert hasbl
  for pf in "$pd"/*.json; do
    [ -e "$pf" ] || continue
    # One guarded read: a file drained away mid-tick is a skip, not a set -e death.
    # Process liveness needs a baseline (registered peer); ack-timeliness (whether
    # the worker READ the message) is the expectation's state and needs no probe.
    rec="$(jq -r '[.state,.peer,.id,.flat,(.ticks // 0),(.baseline|tojson),(.alerted // "")] | @tsv' "$pf" 2>/dev/null)" || continue
    IFS=$'\t' read -r state peer id flat ticks baseline prev <<<"$rec"
    [ "$state" = "awaiting_orch" ] && continue
    ticks=$((ticks + 1))
    verdict=""
    if [ "$baseline" != "null" ]; then
      cur="$(probe_snapshot "$peer")" || continue
      verdict="$(classify "$baseline" "$cur")"
      case "$verdict" in
        working | retrying) flat=0 ;;
        idle)               flat=$((flat + 1)) ;;
      esac
    fi
    # Priority: dead/oom (process gone) > unacked (never read) > stalled (idle).
    unlive=""
    case "$verdict" in
      dead) unlive="dead" ;;
      oom)  unlive="oom" ;;
    esac
    if [ -z "$unlive" ] && [ "$state" = "sent" ] && [ "$ticks" -ge "$ack_max" ]; then
      unlive="unacked"
    fi
    if [ -z "$unlive" ] && [ "$verdict" = idle ] && [ "$flat" -ge "$flat_max" ]; then
      unlive="stalled"
    fi
    # Alert once per expectation, but let a fatal verdict (dead/oom) escalate past
    # a prior non-fatal alert (e.g. unacked then later OOM). `prev` (from the read
    # above) is the alerted verdict; '.alerted // ""' maps false and absent to "".
    do_alert=""
    if [ -n "$unlive" ]; then
      if [ -z "$prev" ]; then
        do_alert=1
      else
        case "$unlive" in
          dead | oom) case "$prev" in dead | oom) ;; *) do_alert=1 ;; esac ;;
        esac
      fi
    fi
    # Persist under a per-orchestrator lock, re-checking existence inside it, so a
    # concurrent drain's rm or state-change is neither resurrected nor clobbered.
    # The alert fires only if the expectation still exists (not just-closed); each
    # alert is a distinct message (fresh id) with the expectation id in the body.
    # Roll the baseline forward (when we probed) so 'idle' is a per-tick diff.
    hasbl=""; [ "$baseline" != "null" ] && hasbl=1
    (
      flock 9
      [ -e "$pf" ] || exit 0
      [ -n "$do_alert" ] && publish "$orch" monitor alert "$(gen_id)" "$id" "$unlive $peer $id"
      if jq --argjson f "$flat" --argjson t "$ticks" --arg v "$unlive" \
        --argjson cur "${cur:-null}" --arg al "${do_alert:-}" --arg bl "${hasbl:-}" \
        '.flat=$f | .ticks=$t
         | (if $al=="1" then .alerted=$v else . end)
         | (if $bl=="1" then .baseline=$cur else . end)' \
        "$pf" > "$pf.w.$$" 2>/dev/null; then mv -- "$pf.w.$$" "$pf"; else rm -f -- "$pf.w.$$"; fi
    ) 9>"$pd/.lock" || true
  done
  # A watched target holds no expectation, so its liveness lives here on three axes,
  # in priority order: dead (its registered process tree is gone: OOM, crash), then
  # erroring (alive, but its transcript tail is an unresolved API error: rate limit,
  # server error), then stale (its inbox stops draining). Each axis has its OWN dedup
  # marker (da/ea/sa) so a lower axis masked by a transient higher one (a stuck sink
  # that then gets rate-limited) is NOT re-alerted when the higher clears — only a
  # genuinely new condition (fresh error status, fresh stuck message, or a recovered-
  # then-failed axis) alerts. Markers store non-empty via a "-" sentinel so the
  # empty-able `last` stays the final @tsv field (a middle empty would collapse under
  # read's IFS-whitespace and shift the columns).
  local wf wrec target dmax last wticks da ea sa role oldest oid nlast nticks kav wknown walive mtr el errstatus isdead curstale abody wdo wgc gkav gknown galive
  for wf in "$wd"/*.json; do
    [ -e "$wf" ] || continue
    wrec="$(jq -r '[.target,(.drain_max // 2),(.ticks // 0),(.da // "-"),(.ea // "-"),(.sa // "-"),(.role // "supervisor"),(.last // "")] | @tsv' "$wf" 2>/dev/null)" || continue
    IFS=$'\t' read -r target dmax wticks da ea sa role last <<<"$wrec"
    [ "$da" = - ] && da=""; [ "$ea" = - ] && ea=""; [ "$sa" = - ] && sa=""
    name_ok "$target" || continue
    # roll the drain-staleness counter: same oldest persisting is the stall
    oldest="$(oldest_msg "$target")"; oid="${oldest%%.from-*}"
    if [ -z "$oldest" ]; then
      nlast=""; nticks=0
    elif [ "$oldest" = "$last" ]; then
      nlast="$oldest"; nticks=$((wticks + 1))
    else
      nlast="$oldest"; nticks=1
    fi
    # sample each axis's current condition
    kav="$(jq -r '[.known,.alive] | @tsv' <<<"$(probe_snapshot "$target")")" || kav=""
    IFS=$'\t' read -r wknown walive <<<"$kav"
    errstatus=""
    mtr="$(jq -r '.transcript // ""' "$(meta_file "$target")" 2>/dev/null)" || mtr=""
    if [ -n "$mtr" ] && [ -f "$mtr" ]; then
      el="$(tail -n1 "$mtr" 2>/dev/null)" || el=""
      [ "$(jq -r '.isApiErrorMessage // false' <<<"$el" 2>/dev/null)" = true ] \
        && errstatus="$(jq -r '.apiErrorStatus // "err"' <<<"$el" 2>/dev/null)"
    fi
    isdead=""; [ "$wknown" = true ] && [ "$walive" = 0 ] && isdead=1
    curstale=""; [ -n "$oldest" ] && [ "$nticks" -ge "$dmax" ] && curstale="$oid"
    # an axis whose condition went inactive re-arms (its marker clears)
    [ -z "$isdead" ] && da=""
    [ -z "$errstatus" ] && ea=""
    [ -z "$curstale" ] && sa=""
    # emit the highest-priority ACTIVE axis, once per distinct value (per-axis dedup).
    # A dead ephemeral target is a normal exit: no alarm, and GC the record so a
    # churning worker fleet does not accumulate stale watches. A dead supervisor is
    # the alarm (its unexpected exit is the whole point).
    wdo=""; abody=""; wgc=""
    if [ -n "$isdead" ]; then
      if [ "$role" = ephemeral ]; then
        wgc=1
        # died mid-error: the worker is a casualty of the rate limit, not a clean
        # exit — surface it once (deduped) before the record is GC'd.
        [ -n "$errstatus" ] && [ "$ea" != "$errstatus" ] && { wdo=1; abody="erroring $target $errstatus (exited)"; }
      else
        [ "$da" != 1 ] && { wdo=1; abody="dead $target"; }; da=1
      fi
    elif [ -n "$errstatus" ]; then
      [ "$ea" != "$errstatus" ] && { wdo=1; abody="erroring $target $errstatus"; }; ea="$errstatus"
    elif [ -n "$curstale" ]; then
      [ "$sa" != "$curstale" ] && { wdo=1; abody="stale $target $oid"; }; sa="$curstale"
    fi
    (
      flock 9
      [ -e "$wf" ] || exit 0
      if [ -n "$wgc" ]; then
        # Re-confirm death under the lock before the destructive GC: a same-name
        # respawn between the unlocked probe and here must keep its fresh record and
        # not inherit the prior incarnation's stale erroring alert.
        gkav="$(jq -r '[.known,.alive] | @tsv' <<<"$(probe_snapshot "$target")")" || gkav=""
        IFS=$'\t' read -r gknown galive <<<"$gkav"
        if [ "$gknown" = true ] && [ "$galive" = 0 ]; then
          [ -n "$wdo" ] && publish "$orch" monitor alert "$(gen_id)" "" "$abody"
          rm -f -- "$wf"
        fi
        exit 0
      fi
      [ -n "$wdo" ] && publish "$orch" monitor alert "$(gen_id)" "" "$abody"
      if jq --arg da "${da:--}" --arg ea "${ea:--}" --arg sa "${sa:--}" --arg l "$nlast" --argjson t "$nticks" \
        '.da=$da | .ea=$ea | .sa=$sa | .last=$l | .ticks=$t' "$wf" > "$wf.w.$$" 2>/dev/null; then
        mv -- "$wf.w.$$" "$wf"; else rm -f -- "$wf.w.$$"; fi
    ) 9>"$wd/.lock" || true
  done
  return 0
}

# monitor <orch> -- background this. Ticks every CLAUDE_BUS_TICK seconds until no
# open expectation remains, sending only unliveness into the orchestrator's inbox.
# The monitor is HOST-ONLY. Metas store host-absolute cgroup paths; inside a sandbox
# (a dbox has no usable host cgroupfs) every probe reads dead, which is not just false
# `dead` alarms but — with the ephemeral GC — silent deletion of LIVE workers. So the
# monitor must refuse to run where it cannot read host cgroups. A supervisor belongs
# outside the sessions it supervises anyway. Three independent signals: IS_SANDBOX
# (set by dbox); a readable cgroup root; and the host `user.slice` hierarchy the metas
# live under (a private-cgroup-ns container has a readable root but no user.slice, so
# the env marker alone is not enough — a rootless podman leaf slips past it). cg_base
# is reused so the guard resolves cgroups exactly as the probes do.
monitor_host_ok() {
  [ -z "${IS_SANDBOX:-}" ] || return 1
  [ -r "$(cg_base /cgroup.procs)" ] || return 1
  [ -d "$(cg_base /user.slice)" ] || return 1
  return 0
}

# Guard-or-exit for the two host-only entry points (the monitor loop and a bare tick).
monitor_require_host() {
  monitor_host_ok || { printf 'monitor: refusing to run — no usable host cgroupfs (a sandbox?). The monitor is HOST-ONLY: run it from a host shell, not inside a session, or it would read every agent dead and GC live workers.\n' >&2; exit 8; }
}

cmd_monitor() {
  local orch="$1"; valid_name "$orch"
  monitor_require_host
  local tick="${CLAUDE_BUS_TICK:-180}"
  local pd; pd="$(pending_dir "$orch")"
  local wd; wd="$(watch_dir "$orch")"
  tip "monitoring $orch; unliveness will arrive in its inbox as kind 'alert'"
  while :; do
    cmd_monitor_tick "$orch"
    local any=0 f
    for f in "$pd"/*.json "$wd"/*.json; do [ -e "$f" ] && { any=1; break; }; done
    (( any )) || break
    sleep "$tick"
  done
}

# have_mail <dir> -- exit 0 if the inbox has any .msg (nullglob-safe: no shopt).
have_mail() { local f; for f in "$1"/*.msg; do [ -e "$f" ] && return 0; done; return 1; }

cmd_wait() {
  local me="${1:?usage: claude-bus wait <me>}"; valid_name "$me"
  local dir; dir="$(inbox_dir "$me")"
  mkdir -p "$dir"; : > "$dir/.keep"
  local poll="${CLAUDE_BUS_POLL:-2}"
  # Already have mail? return now instead of blocking (closes the re-arm race).
  have_mail "$dir" && { printf 'mail waiting\n'; return 0; }
  # Real push where a watcher is installed (entr blocks until a new file lands).
  # Graceful poll fallback where it is not, so a sandbox without entr degrades to
  # polling instead of exiting 127 -- the highest-volume drainer must not die here.
  if command -v entr >/dev/null 2>&1; then
    # entr -d exits 2 when a new file lands (its success signal); normalize to 0
    # so a genuine wake is not reported as a failure by a harness watching rc.
    local rc=0
    printf '%s/.keep\n' "$dir" | entr -dnp /bin/true || rc=$?
    [ "$rc" -eq 2 ] && rc=0
    return "$rc"
  fi
  while :; do
    have_mail "$dir" && return 0
    sleep "$poll"
  done
}

main() {
  set -euo pipefail
  command -v jq >/dev/null 2>&1 || { printf 'claude-bus: jq is required\n' >&2; exit 1; }
  case "${1:-}" in
    init)      shift; cmd_init      "$@";;
    register)  shift; cmd_register  "$@";;
    delegate)  shift; cmd_delegate  "$@";;
    undelegate) shift; cmd_undelegate "$@";;
    watch)     shift; cmd_watch     "$@";;
    unwatch)   shift; cmd_unwatch   "$@";;
    send)      shift; cmd_send      "$@";;
    send-path) shift; cmd_send_path "$@";;
    dispatch)  shift; cmd_dispatch  "$@";;
    probe-snapshot) shift; probe_snapshot "$@";;
    classify)  shift; classify       "$@";;
    reply)     shift; cmd_reply     "$@";;
    forward)   shift; cmd_forward   "$@";;
    pending)   shift; cmd_pending   "$@";;
    close)     shift; cmd_close     "$@";;
    monitor-tick) shift; monitor_require_host; cmd_monitor_tick "$@";;
    monitor)   shift; cmd_monitor   "$@";;
    drain)     shift; cmd_drain     "$@";;
    wait)      shift; cmd_wait      "$@";;
    *) printf 'usage: claude-bus {init|register|delegate|undelegate|watch|unwatch|send|send-path|dispatch|reply|forward|pending|close|drain|wait|monitor}\n' >&2; exit 2;;
  esac
}

[[ "${BASH_SOURCE[0]}" == "${0}" ]] && main "$@"

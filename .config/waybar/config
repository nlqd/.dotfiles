{
    "layer": "bottom",
    "position": "top",
    "height": 30,

    "modules-left": [
        "sway/workspaces",
        "sway/mode",
    ],
    "modules-center": [
        "custom/server-mode",
        "clock#date",
        "clock#time",
        "battery",
    ],
    "modules-right": [
        "tray",
        "network",
        "memory",
        "cpu",
        // "temperature",
        "custom/keyboard-layout",
        "backlight",
        "pulseaudio",
        "pulseaudio#mic",
    ],

    // -------------------------------------------------------------------------
    // Modules
    // -------------------------------------------------------------------------

    "battery": {
        "interval": 10,
        "states": {
            "warning": 30,
            "critical": 15
        },
        // Connected to AC
        "format": "’ā¦  {icon}  {capacity}%~{time}~{power:4.2f}", // Icon: bolt
        // Not connected to AC
        "format-discharging": "{icon}  {capacity}%~{time}~{power:4.2f}W",
        "format-time": "{H}h{M}",
        "format-icons": [
            "’ēä", // Icon: battery-full
            "’ēā", // Icon: battery-three-quarters
            "’ēé", // Icon: battery-half
            "’ēü", // Icon: battery-quarter
            "’ēĆ"  // Icon: battery-empty
        ],
        "tooltip": false
    },

    "clock#time": {
        "interval": 1,
        "format": "{:%H:%M}",
        "tooltip": false
    },

    "clock#date": {
        "interval": 10,
        "format": "{:%d/%m/%y}",
        "tooltip": false,
    },

    "cpu": {
        "interval": 5,
        "format": "’ŗø {usage}%", // Icon: microchip
        "states": {
            "warning": 70,
            "critical": 90
        }
    },

    "custom/keyboard-layout": {
        "exec": "ibus engine",
        "on-click": "/home/qd/Dev/personal/dotfiles/.local/scripts/ibus-toggle",
        "signal": 3,
        "format": "’ä£  {}", // Icon: keyboard
        "tooltip": false
    },

    "custom/player": {
        "exec": "playerctl metadata title",
        "interval": 5,
        "format": "  {}",
        "tooltip": true,
        "tooltip-format": "playerctl metadata artist",
    },

    "custom/server-mode": {
        "exec": "/home/qd/.local/scripts/sway-server-mode-status",
        "on-click": "/home/qd/.local/scripts/sway-server-mode-toggle",
        "return-type": "json",
        "signal": 4,
        "interval": 10,
        "format": "{}",
        "tooltip": true
    },

    "memory": {
        "interval": 5,
        "format": "¾░Źø {}%", // Icon: memory
        "states": {
            "warning": 70,
            "critical": 90
        }
    },

    "network": {
        "interval": 5,
        "format-wifi": "’ć½  {signalStrength}%", // Icon: wifi
        "format-ethernet": "’×¢  {ifname}", // Icon: ethernet
        "format-disconnected": "ŌÜĀ  Disconnected",
        "tooltip-format": "{essid}: {ifname}: {ipaddr}"
    },

    "sway/mode": {
        "format": "<span style=\"italic\">’ī×  {}</span>", // Icon: expand-arrows-alt
        "tooltip": false
    },

    "sway/window": {
        "format": "{}",
        "max-length": 100
    },

    "sway/workspaces": {
        "all-outputs": false,
        "disable-scroll": true,
        "format": "{icon} {name}",
        "format-icons": {
            "1:www": "’żć", // Icon: firefox-browser
            "2:mail": "’ŖČ", // Icon: mail
            "3:editor": "’äĪ", // Icon: code
            "4:terminals": "’äĀ", // Icon: terminal
            "5:portal": "’äĀ", // Icon: terminal
            "urgent": "’ü¬",
            "focused": "’åÆ",
            "default": "’äæ"
        }
    },

    "pulseaudio": {
        "scroll-step": 0.3,
        "format": "{icon}  {volume}%",
        "format-bluetooth": "{icon}  {volume}%’Ŗö",
        "format-muted": "’Ć”",
        "format-icons": {
            "headphones": "’Ćź",
            "handsfree": "’Ćź",
            "headset": "’Ćź",
            "phone": "’éĢ",
            "portable": "’éĢ",
            "car": "’å╣",
            "default": ["’Ć¦", "’Ć©"]
        },
        "on-click": "pavucontrol"
    },

    "pulseaudio#mic": {
        "format": "{format_source}",
        "format-source": "",
        "format-source-muted": "muted",
        "on-click": "pactl set-source-mute @DEFAULT_SOURCE@ toggle"
    },

    "temperature": {
        "critical-threshold": 80,
        "interval": 5,
        "format": "{icon}  {temperatureC}┬░C",
        "format-icons": [
            "’ŗŗ", // Icon: temperature-empty
            "’ŗŖ", // Icon: temperature-quarter
            "’ŗē", // Icon: temperature-half
            "’ŗł", // Icon: temperature-three-quarters
            "’ŗł"  // Icon: temperature-full
        ]
    },

    "tray": {
        "icon-size": 18,
        "spacing": 10
    },

    "backlight": {
        "device": "intel_backlight",
        "format": "’öó  {percent}%",
    },

}


{
    "layer": "bottom",
    "position": "top",
    "height": 30,

    "modules-left": [
        "sway/workspaces",
        "sway/mode",
    ],
    "modules-center": [
        "custom/server-mode",
        "clock#date",
        "clock#time",
        "battery",
    ],
    "modules-right": [
        "tray",
        "network",
        "memory",
        "cpu",
        // "temperature",
        "backlight",
        "pulseaudio",
        "pulseaudio#mic",
        "custom/wireguard",
    ],

    // -------------------------------------------------------------------------
    // Modules
    // -------------------------------------------------------------------------

    "battery": {
        "interval": 10,
        "states": {
            "warning": 30,
            "critical": 15
        },
        // Connected to AC
        "format": "´âğ  {icon}  {capacity}%~{time}~{power:4.2f}", // Icon: bolt
        // Not connected to AC
        "format-discharging": "{icon}  {capacity}%~{time}~{power:4.2f}W",
        "format-time": "{H}h{M}",
        "format-icons": [
            "´ëä", // Icon: battery-full
            "´ëâ", // Icon: battery-three-quarters
            "´ëé", // Icon: battery-half
            "´ëü", // Icon: battery-quarter
            "´ëÇ"  // Icon: battery-empty
        ],
        "tooltip": false
    },

    "clock#time": {
        "interval": 1,
        "format": "{:%H:%M}",
        "tooltip": false
    },

    "clock#date": {
        "interval": 10,
        "format": "{:%d/%m/%y}",
        "tooltip": false,
    },

    "cpu": {
        "interval": 5,
        "format": "´ïø {usage}%", // Icon: microchip
        "states": {
            "warning": 70,
            "critical": 90
        }
    },

    "custom/player": {
        "exec": "playerctl metadata title",
        "interval": 5,
        "format": "  {}",
        "tooltip": true,
        "tooltip-format": "playerctl metadata artist",
    },

    "custom/server-mode": {
        "exec": "/home/qd/.local/scripts/sway-server-mode-status",
        "return-type": "json",
        "signal": 4,
        "interval": 10,
        "format": "{}",
        "tooltip": true
    },

    "custom/wireguard": {
        "format": "{}",
        "exec": "echo VPN",
        "exec-if": "ip link show ea 2>/dev/null",
        "interval": 30,
        "return-type": "",
        "tooltip": false
    },

    "memory": {
        "interval": 5,
        "format": "¾░ıø {}%", // Icon: memory
        "states": {
            "warning": 70,
            "critical": 90
        }
    },

    "network": {
        "interval": 5,
        // "format-wifi": "´ç½  {signalStrength}%", // Icon: wifi
        "format-wifi": "´ç½  {bandwidthDownBits}", // Icon: wifi
        "format-ethernet": "´Şû  {ifname}", // Icon: ethernet
        "format-disconnected": "ÔÜá  Disconnected",
        "tooltip-format": "{essid}: {ifname}: {ipaddr}"
    },

    "sway/mode": {
        "format": "<span style=\"italic\">´îŞ  {}</span>", // Icon: expand-arrows-alt
        "tooltip": false
    },

    "sway/window": {
        "format": "{}",
        "max-length": 100
    },

    "sway/workspaces": {
        "all-outputs": false,
        "disable-scroll": true,
        "format": "{icon} {name}",
        "format-icons": {
            "1:www": "´ñç", // Icon: firefox-browser
            "2:mail": "´èÂ", // Icon: mail
            "3:editor": "´äí", // Icon: code
            "4:terminals": "´äá", // Icon: terminal
            "5:portal": "´äá", // Icon: terminal
            "urgent": "´ü¬",
            "focused": "´åÆ",
            "default": "´äæ"
        }
    },

    "pulseaudio": {
        "scroll-step": 0.3,
        "format": "{icon}  {volume}%",
        "format-bluetooth": "{icon}  {volume}%´èö",
        "format-muted": "´ÇĞ",
        "format-icons": {
            "headphones": "´ÇÑ",
            "handsfree": "´ÇÑ",
            "headset": "´ÇÑ",
            "phone": "´éò",
            "portable": "´éò",
            "car": "´å╣",
            "default": ["´Çğ", "´Ç¿"]
        },
        "on-click": "pavucontrol"
    },

    "pulseaudio#mic": {
        "format": "{format_source}",
        "format-source": "",
        "format-source-muted": "muted",
        "on-click": "pactl set-source-mute @DEFAULT_SOURCE@ toggle"
    },

    "temperature": {
        "critical-threshold": 80,
        "interval": 5,
        "format": "{icon}  {temperatureC}┬░C",
        "format-icons": [
            "´ïï", // Icon: temperature-empty
            "´ïè", // Icon: temperature-quarter
            "´ïë", // Icon: temperature-half
            "´ïê", // Icon: temperature-three-quarters
            "´ïê"  // Icon: temperature-full
        ]
    },

    "tray": {
        "icon-size": 18,
        "spacing": 10
    },

    "backlight": {
        "device": "intel_backlight",
        "format": "´öó  {percent}%",
    },

}


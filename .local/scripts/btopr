#!/bin/sh

cols=$(tput cols)
rows=$(tput lines)

if [ "$cols" -ge 80 ] && [ "$rows" -ge 24 ]; then
    exec btop "$@"
elif [ "$cols" -ge 60 ] && [ "$rows" -ge 24 ]; then
    exec btop --preset 2 "$@"
elif [ "$cols" -ge 60 ] && [ "$rows" -ge 8 ]; then
    exec btop --preset 4 "$@"
else
    echo "Terminal too small for btop (need at least 60x8)" >&2
    exit 1
fi

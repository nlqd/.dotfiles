#!/usr/bin/env bash

# Colors
WEEKDAY='\033[0;34m'  # Blue for weekdays (Mon-Fri)
WEEKEND='\033[0;31m'  # Red for weekends (Sat-Sun)
RESET='\033[0m'

ncal_output=$(ncal -M -y "$@")

# Highlight today only when viewing the current year
highlight_today=false
current_year=$(date +%Y)
first_line=$(head -1 <<< "$ncal_output")
if [[ "$first_line" == *"$current_year"* ]]; then
  highlight_today=true
  today_day=$(date +%-d)
  today_month=$(date +%-m)
  today_dow=$(date +%u)  # 1=Mon .. 7=Sun, matches ncal row order
  target_block=$(( (today_month - 1) / 4 ))
  month_in_block=$(( (today_month - 1) % 4 ))
  hl_on=$(printf '\033[7m')
  hl_off=$(printf '\033[27m')
fi

line_num=0
current_block=-1
month_col_start=-1
month_col_end=-1

# ncal -y structure: line 1 = year, then 3 blocks of (1 month header + 7 day rows + 1 blank)
# Day rows 1-5 = Mon-Fri, rows 6-7 = Sat-Sun, row 8 = blank separator
while IFS= read -r line; do
  line_num=$((line_num + 1))

  if [[ $line_num -eq 1 ]]; then
    echo "$line"
    continue
  fi

  block_row=$(( (line_num - 2) % 9 ))

  if [[ $block_row -eq 8 ]]; then
    echo "$line"
    continue
  fi

  if [[ $block_row -eq 0 ]]; then
    current_block=$(( (line_num - 2) / 9 ))

    if $highlight_today && [[ $current_block -eq $target_block ]]; then
      col_width=$(( ${#line} / 4 ))
      month_col_start=$(( month_in_block * col_width ))
      if [[ $month_in_block -eq 3 ]]; then
        month_col_end=${#line}
      else
        month_col_end=$(( (month_in_block + 1) * col_width ))
      fi
    fi

    echo "$line"
    continue
  fi

  if $highlight_today && [[ $current_block -eq $target_block ]] && [[ $block_row -eq $today_dow ]] && [[ $month_col_start -ge 0 ]]; then
    prefix="${line:0:$month_col_start}"
    portion="${line:$month_col_start:$((month_col_end - month_col_start))}"
    suffix="${line:$month_col_end}"
    portion=$(printf '%s' "$portion" | sed -E "s/(^| )(${today_day})( |$)/\1${hl_on}\2${hl_off}\3/")
    line="${prefix}${portion}${suffix}"
  fi

  if [[ $block_row -le 5 ]]; then  # rows 1-5 = Mon-Fri
    echo -e "${WEEKDAY}${line}${RESET}"
  else
    echo -e "${WEEKEND}${line}${RESET}"
  fi
done <<< "$ncal_output"

# Vietnamese lunar calendar info
echo ""
echo -e "\033[0;33mÂm lịch hôm nay:\033[0m $(node ~/.local/scripts/lunar-date.js 2>/dev/null || echo 'Cài đặt: npm install -g vietnamese-lunar-calendar')"

#!/usr/bin/bash

set -euo pipefail

DBOX_PROFILE=dclaude
source "$HOME/.local/scripts/dbox-lib.sh"

# Profile is a row in the tables below, keyed by how we were invoked:
#   dclaude -> default,  dclaude-jen -> jen,  dclaude-rem -> rem
# (jen and rem are symlinks to this file). Rows set only their delta from
# default; an unset cell falls back to [default] via ${x[$p]-${x[default]}}.
p=$(basename "$0"); p=${p#dclaude}; p=${p#-}; p=${p:-default}

declare -A JSON CREDS GITMODE BLOCK FEAT

JSON[default]=$HOME/.claude.json
CREDS[default]=$HOME/.claude/.credentials.json
GITMODE[default]=ro
BLOCK[default]="gh rsync aws kubectl helm terraform docker heroku"
FEAT[default]=

# rem: separate identity under ~/.claude-rem, with git push (so gh stays unblocked)
JSON[rem]=$HOME/.claude-rem/.claude.json
CREDS[rem]=$HOME/.claude-rem/.credentials.json
GITMODE[rem]=rw
BLOCK[rem]=
FEAT[rem]="git_push podman bind_parent"

# jen: jenner-web, full toolchain, git push, podman, R
JSON[jen]=$HOME/.claude.json
CREDS[jen]=$HOME/.claude/.credentials.json
GITMODE[jen]=rw
BLOCK[jen]=
FEAT[jen]="git_push podman bind_parent"

read -ra block <<<"${BLOCK[$p]-${BLOCK[default]}}"
read -ra feat  <<<"${FEAT[$p]-${FEAT[default]}}"

dbox_parse "$@"
dbox_namespaces
dbox_system
dbox_block "${block[@]}"
dbox_home
dbox_dotfiles
dbox_tmux
dbox_claude "${JSON[$p]-${JSON[default]}}" "${CREDS[$p]-${CREDS[default]}}"
for f in "${feat[@]}"; do "dbox_feat_$f"; done
dbox_resolve_links "${GITMODE[$p]-${GITMODE[default]}}"
dbox_shared "${DBOX_SHARES[@]}"
dbox_project "$DBOX_MODE"

dbox_exec claude --dangerously-skip-permissions "${DBOX_REST[@]}"

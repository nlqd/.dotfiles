#!/usr/bin/bash
# Interactive sandboxed zsh (with GPU passthrough). For the user's own use, so
# nothing is blocked; it just isolates /tmp, /home, and most of the host while
# keeping the dev environment usable.
set -euo pipefail

DBOX_PROFILE=dshell
source "$HOME/.local/scripts/dbox-lib.sh"
dbox_parse "$@"

dbox_namespaces
dbox_tmux
dbox_add \
    --dev-bind-try /dev/nvidia0 /dev/nvidia0 \
    --dev-bind-try /dev/nvidiactl /dev/nvidiactl \
    --dev-bind-try /dev/nvidia-modeset /dev/nvidia-modeset \
    --dev-bind-try /dev/nvidia-uvm /dev/nvidia-uvm \
    --dev-bind-try /dev/nvidia-uvm-tools /dev/nvidia-uvm-tools \
    --dev-bind-try /dev/nvidia-caps /dev/nvidia-caps
dbox_system
dbox_add \
    --ro-bind /usr/local/bin /usr/local/bin \
    --ro-bind-try /usr/share/doc /usr/share/doc \
    --ro-bind-try /usr/share/zsh /usr/share/zsh

dbox_home
dbox_add \
    --ro-bind "$HOME/.bashrc" "$HOME/.bashrc" \
    --ro-bind "$HOME/.profile" "$HOME/.profile" \
    --ro-bind-try "$HOME/.gitconfig" "$HOME/.gitconfig" \
    --ro-bind "$HOME/.local/bin" "$HOME/.local/bin" \
    --ro-bind "$HOME/.local/scripts" "$HOME/.local/scripts" \
    --ro-bind-try "$HOME/.local/share/fonts" "$HOME/.local/share/fonts" \
    --ro-bind "$HOME/.zshrc" "$HOME/.zshrc" \
    --ro-bind-try "$HOME/.zshrc.aiws" "$HOME/.zshrc.aiws" \
    --ro-bind-try "$HOME/.oh-my-zsh" "$HOME/.oh-my-zsh" \
    --ro-bind "$HOME/.cargo" "$HOME/.cargo" \
    --ro-bind-try "$HOME/miniconda3" "$HOME/miniconda3" \
    --bind "$HOME/.cache" "$HOME/.cache"

dbox_shared "${DBOX_SHARES[@]}"
dbox_project "$DBOX_MODE"

dbox_exec zsh "${DBOX_REST[@]}"

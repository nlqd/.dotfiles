#:[story_followers add_follower] POST /projects/{project_id}/stories/{story_id}/followers
#:[story_followers add_follower] body: agent_id member_id
#:[story_agents remove_agent_follower] DELETE /projects/{project_id}/stories/{story_id}/followers/agents/{agent_id}

#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10"
# dependencies = [
#     "python-xlib",
# ]
# ///
"""Convert clipboard markdown to a rich-paste-able clipboard.

One clipboard, two MIME types where possible: rich-text targets (Slack,
Google Docs, email) get `text/html`; plain-text targets get the original
markdown source. The plain branch is markdown rather than Slack mrkdwn
on purpose — GitHub's editor pastes from text/plain and parses it as
markdown, so a Slack-shaped payload would render wrong there.

On X11 we own the CLIPBOARD selection directly via the X protocol
(python-xlib) and respond to TARGETS/format requests ourselves — this is
what lets us serve `text/html` and `text/plain` from a single copy.

On native Wayland there is no pure-Python multi-MIME path. We fall back
to `wl-copy --type text/html`, which works for Google Docs, email, and
other rich-paste targets, but Slack on Wayland may not paste rich since
it expects a plain-text fallback alongside.

Script double-forks on X11 so the dmenu/keybind caller returns at once;
the daemon exits when another app takes the selection. On Wayland the
forking is delegated to wl-copy.
"""

import os
import re
import subprocess
import sys


def notify(msg: str) -> None:
    subprocess.run(
        ["notify-send", "--urgency=critical", "md2slack", msg],
        check=False,
    )


def is_wayland() -> bool:
    return bool(os.environ.get("WAYLAND_DISPLAY"))


def read_clipboard() -> str:
    cmd = (
        ["wl-paste", "--no-newline"]
        if is_wayland()
        else ["xclip", "-selection", "clipboard", "-o"]
    )
    return subprocess.run(cmd, capture_output=True, text=True, check=True).stdout


def to_html(md: str) -> str:
    html = subprocess.run(
        ["pandoc", "--from=gfm", "--to=html", "--wrap=none", "--no-highlight"],
        input=md,
        capture_output=True,
        text=True,
        check=True,
    ).stdout
    # Slack ignores <h1..h6> and <del>; remap to tags it does render.
    html = re.sub(
        r"<h[1-6][^>]*>(.*?)</h[1-6]>",
        r"<p><strong>\1</strong></p>",
        html,
        flags=re.DOTALL,
    )
    html = re.sub(r"<(/?)del>", r"<\1s>", html)
    # Slack collapses <p> margins on paste, so blank lines between blocks
    # in the source disappear. Insert an empty paragraph at each block
    # boundary to make the spacing visible in the rendered output.
    html = re.sub(
        r"(</(?:p|ul|ol|pre|blockquote|table)>)\s*(<(?:p|ul|ol|pre|blockquote|table)\b)",
        r"\1<p><br></p>\2",
        html,
    )
    return html


def daemonize() -> None:
    if os.fork() > 0:
        os._exit(0)
    os.setsid()
    if os.fork() > 0:
        os._exit(0)
    devnull = os.open(os.devnull, os.O_RDWR)
    for fd in (0, 1, 2):
        os.dup2(devnull, fd)
    os.close(devnull)


def hold_clipboard_x11(html: str, plain: str) -> None:
    from Xlib import X, Xatom, display
    from Xlib.protocol.event import SelectionNotify

    html_b = html.encode("utf-8")
    plain_b = plain.encode("utf-8")

    d = display.Display()
    screen = d.screen()
    win = screen.root.create_window(-10, -10, 1, 1, 0, screen.root_depth)

    CLIPBOARD = d.intern_atom("CLIPBOARD")
    TARGETS = d.intern_atom("TARGETS")
    TIMESTAMP = d.intern_atom("TIMESTAMP")
    TEXT_HTML = d.intern_atom("text/html")
    TEXT_PLAIN_UTF8 = d.intern_atom("text/plain;charset=utf-8")
    UTF8_STRING = d.intern_atom("UTF8_STRING")
    STRING = Xatom.STRING

    SUPPORTED = [TARGETS, TIMESTAMP, TEXT_HTML, UTF8_STRING, TEXT_PLAIN_UTF8, STRING]

    win.set_selection_owner(CLIPBOARD, X.CurrentTime)
    d.sync()
    if d.get_selection_owner(CLIPBOARD).id != win.id:
        return

    while True:
        event = d.next_event()

        if event.type == X.SelectionClear and event.atom == CLIPBOARD:
            return

        if event.type != X.SelectionRequest:
            continue

        # Legacy clients may leave property as None; conventional fallback
        # is to use the target atom as the destination property name.
        prop = event.property if event.property != X.NONE else event.target
        target = event.target

        if target == TARGETS:
            event.requestor.change_property(prop, Xatom.ATOM, 32, SUPPORTED)
            reply_prop = prop
        elif target == TIMESTAMP:
            event.requestor.change_property(prop, Xatom.INTEGER, 32, [X.CurrentTime])
            reply_prop = prop
        elif target == TEXT_HTML:
            event.requestor.change_property(prop, target, 8, html_b)
            reply_prop = prop
        elif target in (UTF8_STRING, TEXT_PLAIN_UTF8, STRING):
            event.requestor.change_property(prop, target, 8, plain_b)
            reply_prop = prop
        else:
            reply_prop = X.NONE

        notify_evt = SelectionNotify(
            time=event.time,
            requestor=event.requestor,
            selection=event.selection,
            target=event.target,
            property=reply_prop,
        )
        # event_mask=0 per ICCCM: SelectionNotify is delivered to the requestor
        # regardless of its selected event mask.
        event.requestor.send_event(notify_evt, event_mask=0)
        d.flush()


def set_clipboard_wayland(html: str) -> None:
    # wl-copy backgrounds itself and serves until the selection is replaced.
    subprocess.run(
        ["wl-copy", "--type", "text/html"],
        input=html.encode("utf-8"),
        check=True,
    )


def main() -> int:
    try:
        md = read_clipboard()
        if not md.strip():
            return 0
        html = to_html(md)
    except subprocess.CalledProcessError as e:
        notify(f"{e.cmd[0]}: {(e.stderr or '').strip() or e}")
        return 1
    except Exception as e:
        notify(str(e))
        return 1

    if is_wayland():
        try:
            set_clipboard_wayland(html)
        except Exception as e:
            notify(f"wl-copy: {e}")
            return 1
        return 0

    # text/plain is the original markdown source, not Slack mrkdwn: GitHub's
    # paste handler reads text/plain into its markdown editor where `*x*` is
    # italic, so a Slack-shaped payload would render wrong. Rich-text apps
    # (Slack, Docs, email) read text/html and don't see this string.
    #
    # Flatten `[text](url)` to `text (url)` though — GitHub's paste-markdown
    # otherwise combines our text/plain link with the text/html <a> href and
    # emits a nested `[[text](url)](url)` that won't render as a link.
    plain = re.sub(
        r"(?<!!)\[([^\]]+)\]\(([^)\s]+)(?:\s+\"[^\"]*\")?\)",
        r"\1 (\2)",
        md,
    )

    daemonize()
    hold_clipboard_x11(html, plain)
    return 0


if __name__ == "__main__":
    sys.exit(main())

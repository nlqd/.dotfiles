#!/usr/bin/env python3
"""Streaming Markdown highlighter for terminal output.

Reads Markdown from stdin and emits ANSI-colored output to stdout. Designed
to handle character-level streaming where chunk boundaries may split tokens.

Recognized features: fenced code blocks (``` / ~~~), ATX headings (# .. ######),
inline code (`x`), bold (**x**), italic (*x*), and <think>...</think> blocks.
"""

import codecs
import os
import sys


ESC = "\033["
RESET = f"{ESC}0m"
HEADR = f"{ESC}96m"
FENCE = f"{ESC}33m"
CODE = f"{ESC}92m"
ICOD = f"{ESC}95m"
THINK = f"{ESC}90m"
BOLD = f"{ESC}1m"
ITAL = f"{ESC}3m"

OPEN_THINK = "<think>"
CLOSE_THINK = "</think>"

LINE_NORMAL = "normal"
LINE_HEADING = "heading"
LINE_FENCE_OPEN = "fence_open"


class Highlighter:
    def __init__(self, out=None):
        self.out = out if out is not None else sys.stdout

        self.in_fence = False
        self.fence_char = None
        self.fence_len = 0
        self.fence_run_open = False  # leading-fence-char run still being counted
        self.in_think = False

        self.line_chars = []
        self.line_decided = False
        self.line_mode = LINE_NORMAL

        self.in_inline_code = False
        self.in_bold = False
        self.in_italic = False
        self.pending_star = False
        self.tag_buf = ""

    # ---------------------------------------------------------------- API
    def feed(self, text):
        if not text:
            return
        for ch in text:
            self._process(ch)

    def flush(self):
        if self.line_chars or self.tag_buf or self.pending_star:
            self._end_line(emit_newline=False)
        else:
            self._close_inline_styles()
        if self.in_think:
            self._w(RESET)
            self.in_think = False
        try:
            self.out.flush()
        except Exception:
            pass

    # ----------------------------------------------------------- internals
    def _w(self, s):
        self.out.write(s)

    def _process(self, ch):
        if ch == "\n":
            self._end_line()
            return

        if self.in_fence:
            self.line_chars.append(ch)
            return

        if self.in_think:
            self._inline(ch)
            return

        if not self.line_decided:
            self.line_chars.append(ch)
            self._try_classify_line()
            if self.line_decided:
                buf = "".join(self.line_chars)
                self.line_chars = []
                self._begin_decided_line(buf)
            return

        if self.line_mode == LINE_NORMAL:
            self._inline(ch)
            return

        if self.line_mode == LINE_FENCE_OPEN and self.fence_run_open:
            if ch == self.fence_char:
                self.fence_len += 1
            else:
                self.fence_run_open = False
        self._w(ch)

    # ------------------------------------------------- line classification
    def _try_classify_line(self):
        s = self.line_chars
        n = len(s)
        c0 = s[0]

        if c0 == "#":
            i = 0
            while i < n and s[i] == "#":
                i += 1
            if i > 6:
                self._decide(LINE_NORMAL)
                return
            if i == n:
                return
            self._decide(LINE_HEADING if s[i] == " " else LINE_NORMAL)
            return

        if c0 in ("`", "~"):
            i = 0
            while i < n and s[i] == c0:
                i += 1
            if i >= 3:
                self.fence_char = c0
                self.fence_len = i
                self._decide(LINE_FENCE_OPEN)
                return
            if i == n:
                return
            self._decide(LINE_NORMAL)
            return

        self._decide(LINE_NORMAL)

    def _decide(self, mode):
        self.line_mode = mode
        self.line_decided = True

    def _begin_decided_line(self, buf):
        if self.line_mode == LINE_HEADING:
            self._w(HEADR + buf)
        elif self.line_mode == LINE_FENCE_OPEN:
            self.fence_run_open = len(buf) == self.fence_len
            self._w(FENCE + buf)
        else:
            for c in buf:
                self._inline(c)

    # -------------------------------------------------------- end of line
    def _end_line(self, emit_newline=True):
        if self.in_fence:
            line = "".join(self.line_chars)
            self.line_chars = []
            if self._is_fence_close(line):
                self._w(FENCE + line + RESET)
                self.in_fence = False
            else:
                self._w(CODE + line + RESET)
            if emit_newline:
                self._w("\n")
            return

        self._flush_pending_literals()

        # <think> spans newlines: preserve in_bold/in_italic flags and the
        # THINK color across the boundary so they restore on </think>.
        if not self.in_think:
            self._close_inline_styles()
            if not self.line_decided:
                self._w("".join(self.line_chars))
            if self.line_mode in (LINE_HEADING, LINE_FENCE_OPEN):
                self._w(RESET)
            if self.line_mode == LINE_FENCE_OPEN:
                self.in_fence = True

        if emit_newline:
            self._w("\n")

        self.line_decided = False
        self.line_mode = LINE_NORMAL
        self.line_chars = []

    def _is_fence_close(self, line):
        stripped = line.rstrip()
        return set(stripped) == {self.fence_char} and len(stripped) >= self.fence_len

    # ----------------------------------------------------- inline machine
    def _inline(self, ch):
        if self.in_inline_code:
            if ch == "`":
                self._w("`" + RESET)
                self.in_inline_code = False
                return
            self._w(ch)
            return

        if self.tag_buf or ch == "<":
            candidate = self.tag_buf + ch
            if candidate == OPEN_THINK:
                self.tag_buf = ""
                # Drop any active inline styles around the tag so THINK reads cleanly
                if self.in_bold or self.in_italic:
                    self._w(RESET)
                self._w(THINK + OPEN_THINK)
                self.in_think = True
                return
            if candidate == CLOSE_THINK:
                self.tag_buf = ""
                self._w(CLOSE_THINK + RESET)
                self.in_think = False
                # Restore any inline styles that were active before the tag
                if self.in_bold:
                    self._w(BOLD)
                if self.in_italic:
                    self._w(ITAL)
                return
            if OPEN_THINK.startswith(candidate) or CLOSE_THINK.startswith(candidate):
                self.tag_buf = candidate
                return
            # Tag mismatch: emit accumulated chars as literal text
            self._w(self.tag_buf)
            self.tag_buf = ""
            if ch == "<":
                self.tag_buf = "<"
                return

        if self.in_think:
            self._w(ch)
            return

        if ch == "*":
            if self.pending_star:
                if self.in_bold:
                    self._w("**" + RESET)
                    self.in_bold = False
                else:
                    self._w(BOLD + "**")
                    self.in_bold = True
                self.pending_star = False
            else:
                self.pending_star = True
            return

        self._resolve_pending_star()

        if ch == "`":
            self._w(ICOD + "`")
            self.in_inline_code = True
            return

        self._w(ch)

    def _resolve_pending_star(self):
        if not self.pending_star:
            return
        self.pending_star = False
        if self.in_italic:
            self._w("*" + RESET)
            self.in_italic = False
        elif self.in_bold:
            self._w("*")
        else:
            self._w(ITAL + "*")
            self.in_italic = True

    def _flush_pending_literals(self):
        if self.tag_buf:
            self._w(self.tag_buf)
            self.tag_buf = ""
        if self.pending_star:
            self._w("*")
            self.pending_star = False

    def _close_inline_styles(self):
        if self.in_inline_code or self.in_bold or self.in_italic:
            self._w(RESET)
            self.in_inline_code = False
            self.in_bold = False
            self.in_italic = False


# ----------------------------------------------------------------- main


def _run():
    h = Highlighter()
    decoder = codecs.getincrementaldecoder("utf-8")(errors="replace")
    fd = 0
    try:
        while True:
            chunk = os.read(fd, 4096)
            if not chunk:
                break
            text = decoder.decode(chunk)
            if text:
                h.feed(text)
                sys.stdout.flush()
        tail = decoder.decode(b"", final=True)
        if tail:
            h.feed(tail)
        h.flush()
    except KeyboardInterrupt:
        h.flush()
    except BrokenPipeError:
        try:
            sys.stdout.close()
        except Exception:
            pass
        try:
            sys.stderr.close()
        except Exception:
            pass


if __name__ == "__main__":
    _run()

#!/usr/bin/env bash

# credit: https://gist.github.com/Nimmidev/2cf4d5cc80dce32d0240ec7b3cfe090f

readonly LINE_NUMBER_PANE_WIDTH=3

readonly ESC_HOME="\033[H"
readonly ESC_ERASE_EOL="\033[K"
readonly ESC_ERASE_BELOW="\033[J"
readonly ESC_RESET="\033[0m"
readonly ESC_DIM="\033[2m"
readonly ESC_BOLD="\033[1m"

get_cursor_line() {
  local output
  output=$(tmux display-message -pt "$target_pane" -F '#{copy_cursor_y}')
  echo "${output:-0}"
}

is_in_copy_mode() {
  local mode
  mode=$(tmux display-message -p -t "$target_pane" -F '#{pane_mode}')
  [ -n "$mode" ]
}

redraw_line_numbers() {
  local cursor_line=$1
  local lines
  lines=$(tput lines)

  local out="${ESC_HOME}${ESC_DIM}"
  local i=$cursor_line

  # upper
  while [ "$i" -ge 1 ]; do
    out="${out}${i}${ESC_ERASE_EOL}\n"
    i=$((i - 1))
  done
  out="${out}${ESC_RESET}"

  # current line
  out="${out}${ESC_BOLD} 0${ESC_ERASE_EOL}${ESC_RESET}\n"

  # lower
  if [ "$lines" -gt $((cursor_line + 1)) ]; then
    out="${out}${ESC_DIM}"
    local limit=$((lines - cursor_line - 2))
    i=1
    while [ "$i" -le "$limit" ]; do
      out="${out}${i}${ESC_ERASE_EOL}\n"
      i=$((i + 1))
    done
    out="${out}$((lines - cursor_line - 1))${ESC_ERASE_EOL}${ESC_RESET}"
  fi

  printf "%b%b" "$out" "$ESC_ERASE_BELOW"
}

update_loop() {
  local cursor_line=""
  local last_cursor_line="-1"

  while is_in_copy_mode; do
    cursor_line=$(get_cursor_line)

    if [ "$cursor_line" -ne "$last_cursor_line" ]; then
      redraw_line_numbers "$cursor_line"
      last_cursor_line=$cursor_line
    fi
  done
}

main() {
  local target_pane=$1

  if [ -z "$target_pane" ]; then
    local self_path pane_id
    self_path=$(realpath "$0")
    pane_id=$(tmux display-message -pF "#{pane_id}")

    pgrep -f "$self_path $pane_id" >/dev/null && return

    tmux split-window -h -l $LINE_NUMBER_PANE_WIDTH -b "$self_path $pane_id"
    tmux select-pane -l
    tmux copy-mode
    exit 0
  fi

  until is_in_copy_mode; do
    sleep 0.05
  done

  update_loop
}

main "$@"

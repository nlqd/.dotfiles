#!/usr/bin/env bash
# Per-worktree network "coat": a rootless podman pod gives each git worktree its
# own network namespace, so every worktree runs FE/BE/DB on the SAME default
# ports (3000/8000/5432) without colliding. Nothing is published to the host;
# you reach a service by entering the coat. Rootless, no sudo.
#
# Why a pod: a pod is a persistent netns shared by its containers. Rootful Docker
# can't do this (its daemon publishes ports in the host netns regardless of the
# caller). Rootless podman is daemonless, so the port lands wherever the pod is.
#
# Coat entry uses
#   nsenter --target <infra-pid> --user --net --preserve-credentials
# which keeps your real uid, so files written into the worktree stay yours.
#
# Requires: podman (rootless), nsenter, bash 4+ (Linux only — see `workit help`).

PROG="${0##*/}"

RED="\033[0;31m"
GREEN="\033[0;32m"
YELLOW="\033[0;33m"
CLEAR="\033[0m"

# Postgres knobs, overridable from the environment.
PG_IMAGE="${WORKIT_PG_IMAGE:-docker.io/library/postgres:16-alpine}"
PG_PASSWORD="${WORKIT_PG_PASSWORD:-postgres}"

# Coat-name override used when the git-branch heuristic can't apply. Set by
# --name, or WORKIT_NAME in the environment.
COAT_OVERRIDE="${WORKIT_NAME:-}"

function die {
    printf '%b%s%b\n' "${RED}" "${1}" "${CLEAR}" >&2
    exit 1
}

function warn {
    printf '%b%s%b\n' "${YELLOW}" "${1}" "${CLEAR}" >&2
}

function ok {
    printf '%b%s%b\n' "${GREEN}" "${1}" "${CLEAR}"
}

# Progressive "what to run next" nudge printed after a state-changing command.
function hint {
    printf '  next: %s\n' "${1}"
}

function usage {
    cat <<EOF
${PROG} [-C <dir>] [--name <n>] <command> — per-worktree network "coat" via a rootless podman pod.

Each git worktree gets its own network namespace, so every worktree can run
FE/BE/DB on the SAME default ports (3000/8000/5432) without colliding. Nothing
is published to the host; enter the coat to reach a service. Rootless, no sudo.

  ${PROG}                  show the coat's state here and what to run next
  ${PROG} up               create + start the coat for the current worktree
  ${PROG} enter            open a shell inside the coat
  ${PROG} run -- <cmd>     run <cmd> inside the coat (as you; writes stay yours)
  ${PROG} pid              print the coat's infra PID (build your own nsenter)
  ${PROG} db               start postgres in the coat (localhost:5432, isolated)
  ${PROG} status           show the coat and what's in it
  ${PROG} ls               list all coats; flag orphans whose worktree is gone
  ${PROG} gc [-n]          remove orphaned coats (-n / --dry-run: just list)
  ${PROG} down [--purge]   remove the coat (--purge also drops the db volume)

  -C <dir>                 act on the worktree at <dir> instead of the cwd
  --name <n>               name the coat explicitly (when not in a git worktree)
EOF
    exit "${1:-0}"
}

# Stable, podman-safe coat name for the current worktree. Source, in order:
# an explicit override (--name / WORKIT_NAME), the git branch, or the worktree
# directory name when detached. If none apply (not in a git worktree and no
# override), it can't operate, so it tells you to pass --name. Pure bash.
function coat_name {
    local raw
    if [[ -n "${COAT_OVERRIDE}" ]]; then
        raw="${COAT_OVERRIDE}"
    else
        raw=$(git branch --show-current 2>/dev/null)
        if [[ -z "${raw}" ]]; then
            local top
            top=$(git rev-parse --show-toplevel 2>/dev/null)
            [[ -n "${top}" ]] ||
                die "can't infer a coat name here (not a git worktree). name one: ${PROG} --name <name> ..."
            raw="${top##*/}"
        fi
    fi
    local name="${raw,,}"         # lowercase
    name="${name//[^a-z0-9_-]/-}" # disallowed chars -> dash
    while [[ "${name}" == *--* ]]; do name="${name//--/-}"; done
    name="${name#-}"
    name="${name%-}"
    [[ -n "${name}" ]] || die "could not derive a coat name from '${raw}'"
    printf 'workit-%s' "${name}"
}

# PID of the pod's infra container — the process whose namespaces are the coat.
# Only valid while the pod is running, hence the up-and-running check.
function infra_pid {
    local infra pid
    infra=$(podman pod inspect "${1}" --format '{{.InfraContainerID}}' 2>/dev/null) ||
        die "coat ${1} has no infra container"
    pid=$(podman inspect "${infra}" --format '{{.State.Pid}}' 2>/dev/null) ||
        die "cannot read infra pid for ${1}"
    [[ "${pid}" =~ ^[1-9][0-9]*$ ]] || die "coat ${1} is not running — run: ${PROG} up"
    printf '%s' "${pid}"
}

function require_coat {
    podman pod exists "${1}" 2>/dev/null || die "no coat for ${1} — run: ${PROG} up"
}

# Best-effort name for the sandbox we may be running in, else empty. dbox bwrap
# sandboxes set their UTS hostname to "bubblewrap"; containers leave a marker.
function sandbox_hint {
    local host=""
    read -r host </proc/sys/kernel/hostname 2>/dev/null
    [[ "${host}" == bubblewrap ]] && {
        printf 'a bubblewrap (dbox) sandbox'
        return
    }
    [[ -e /run/.containerenv ]] && {
        printf 'a podman container'
        return
    }
    [[ -e /.dockerenv ]] && printf 'a docker container'
}

# Coat entry is local nsenter, so the infra pid must live in THIS pid namespace.
# It won't when podman is a remote client (CONTAINER_HOST set, e.g. a sandbox
# talking to the host socket): the pod runs on the host and its pid isn't here,
# which otherwise surfaces as a cryptic "nsenter: cannot open /proc/<pid>/ns/*".
# The message has to be self-explaining: the caller may not know it's sandboxed.
function assert_enterable {
    local pid="${1}" pod="${2}" where
    [[ -e "/proc/${pid}" ]] && return 0
    where=$(sandbox_hint)
    printf '%bcannot enter coat %s: its container runs elsewhere, not in this environment.%b\n' \
        "${RED}" "${pod}" "${CLEAR}" >&2
    if [[ -n "${where}" ]]; then
        printf 'You are inside %s, so podman here is a remote client pointing at another host.\n' "${where}" >&2
    fi
    cat >&2 <<EOF
Entering a coat uses local nsenter, which needs the pod's infra process
(pid ${pid}) to live in THIS pid namespace. It does not: podman ran the pod on
the daemon its socket points at, not here. Pointers:

  CONTAINER_HOST = ${CONTAINER_HOST:-unset}
  DOCKER_HOST    = ${DOCKER_HOST:-unset}

Entering that pod's namespaces from here is impossible by design (it would be a
sandbox escape). What works from HERE — talk to the container over the socket:
  podman exec -it ${pod}-db psql -U postgres   # the coat's database
  podman exec -it ${pod}-db <cmd>              # any command in the db container

To truly enter the coat (${PROG} run / enter), run ${PROG} where podman is
local — typically the host, not this sandbox.
EOF
    exit 1
}

# No-arg / progressive guidance: where you are and the next step to run.
function cmd_suggest {
    local pod
    if ! pod=$(coat_name 2>/dev/null); then
        printf '%s — per-worktree network coat.\n' "${PROG}"
        printf "  can't infer a coat name here (not a git worktree).\n"
        printf '  name one explicitly:  %s --name <name> up\n' "${PROG}"
        printf '  full help:            %s help\n' "${PROG}"
        return 0
    fi
    if command -v podman >/dev/null 2>&1 && podman pod exists "${pod}" 2>/dev/null; then
        printf 'coat %s is up.\n' "${pod}"
        printf '  work:     %s run -- <cmd>   |   %s enter   |   %s db\n' "${PROG}" "${PROG}" "${PROG}"
        printf '  inspect:  %s status   |   %s ls\n' "${PROG}" "${PROG}"
        printf '  teardown: %s down [--purge]\n' "${PROG}"
    else
        printf 'no coat yet for %s.\n' "${pod}"
        printf '  set it up:  %s up      then: %s db, %s run -- <cmd>\n' "${PROG}" "${PROG}" "${PROG}"
        printf '  all coats:  %s ls\n' "${PROG}"
        printf '  full help:  %s help\n' "${PROG}"
    fi
}

function cmd_up {
    local pod top branch
    pod=$(coat_name) || exit 1
    # Worktree path/branch are best-effort: a --name coat may live outside a repo.
    top=$(git rev-parse --show-toplevel 2>/dev/null) || top=""
    branch=$(git branch --show-current 2>/dev/null) || branch=""
    [[ -n "${branch}" ]] || branch="(detached)"
    if podman pod exists "${pod}" 2>/dev/null; then
        # Same name from a different worktree => a real collision. Labels let us
        # detect it and refuse, rather than silently reuse the wrong coat.
        local owner
        owner=$(podman pod inspect "${pod}" --format '{{index .Labels "workit.worktree"}}' 2>/dev/null)
        [[ -z "${owner}" || -z "${top}" || "${owner}" == "${top}" ]] ||
            die "coat ${pod} already belongs to another worktree (${owner}); down it first or use a distinct --name"
    else
        podman pod create --name "${pod}" \
            --label workit.worktree="${top}" \
            --label workit.branch="${branch}" >/dev/null ||
            die "failed to create coat ${pod}"
    fi
    # Start the pod so its infra container runs and holds the netns — without
    # this the coat has no enterable namespace.
    podman pod start "${pod}" >/dev/null || die "failed to start coat ${pod}"
    ok "coat ${pod} up"
    hint "${PROG} db (postgres)  |  ${PROG} run -- <cmd>  |  ${PROG} enter"
}

function cmd_enter {
    local pod pid
    pod=$(coat_name) || exit 1
    require_coat "${pod}"
    pid=$(infra_pid "${pod}") || exit 1
    assert_enterable "${pid}" "${pod}"
    exec nsenter --target "${pid}" --user --net --preserve-credentials -- "${SHELL:-/bin/bash}"
}

function cmd_run {
    [[ "${1:-}" == "--" ]] && shift
    [[ "$#" -gt 0 ]] || die "usage: ${PROG} run -- <cmd> [args...]"
    local pod pid
    pod=$(coat_name) || exit 1
    require_coat "${pod}"
    pid=$(infra_pid "${pod}") || exit 1
    assert_enterable "${pid}" "${pod}"
    # --preserve-credentials keeps your real uid, so files written into the
    # worktree stay owned by you (not a remapped subuid).
    exec nsenter --target "${pid}" --user --net --preserve-credentials -- "$@"
}

function cmd_pid {
    local pod pid
    pod=$(coat_name) || exit 1
    require_coat "${pod}"
    pid=$(infra_pid "${pod}") || exit 1
    printf '%s\n' "${pid}"
}

function cmd_db {
    local pod
    pod=$(coat_name) || exit 1
    require_coat "${pod}"
    local name="${pod}-db" vol="${pod}-pgdata"
    if podman container exists "${name}" 2>/dev/null; then
        warn "db ${name} already exists"
        return 0
    fi
    podman run -d --pod "${pod}" --name "${name}" \
        -e POSTGRES_PASSWORD="${PG_PASSWORD}" \
        -v "${vol}:/var/lib/postgresql/data" \
        "${PG_IMAGE}" >/dev/null || die "failed to start postgres in ${pod}"
    ok "postgres up in ${pod} (localhost:5432 inside the coat)"
    hint "${PROG} run -- psql -h localhost -U postgres  |  ${PROG} enter"
}

function cmd_status {
    local pod
    pod=$(coat_name) || exit 1
    if ! podman pod exists "${pod}" 2>/dev/null; then
        echo "coat ${pod}: not up"
        return 0
    fi
    local pid
    pid=$(infra_pid "${pod}") || exit 1
    echo "coat ${pod} (infra pid ${pid})"
    podman ps --pod --filter "pod=${pod}" \
        --format '  {{.Names}}  {{.Image}}  {{.Status}}' 2>/dev/null
}

function cmd_ls {
    local lines
    mapfile -t lines < <(podman pod ps --filter name=workit- --format '{{.Name}}|{{.Status}}' 2>/dev/null || true)
    if [[ ${#lines[@]} -eq 0 ]]; then
        echo "no coats"
        return 0
    fi
    printf '%-30s %-12s %-9s %s\n' COAT STATUS STATE WORKTREE
    local line name status wt state
    for line in "${lines[@]}"; do
        name="${line%%|*}"
        status="${line#*|}"
        wt=$(podman pod inspect "${name}" --format '{{index .Labels "workit.worktree"}}' 2>/dev/null)
        if [[ -z "${wt}" ]]; then
            state="unlabeled"
            wt="?"
        elif [[ -d "${wt}" ]]; then
            state="live"
        else
            state="ORPHAN"
        fi
        printf '%-30s %-12s %-9s %s\n' "${name}" "${status}" "${state}" "${wt}"
    done
}

function cmd_gc {
    local dry=
    [[ "${1:-}" == "-n" || "${1:-}" == "--dry-run" ]] && dry=1
    local names name wt n=0
    mapfile -t names < <(podman pod ps --filter name=workit- --format '{{.Name}}' 2>/dev/null || true)
    for name in "${names[@]}"; do
        wt=$(podman pod inspect "${name}" --format '{{index .Labels "workit.worktree"}}' 2>/dev/null)
        # Only reap coats we can prove are orphaned: labeled with a path that's
        # gone. Unlabeled coats are left alone (we can't know their worktree).
        [[ -n "${wt}" && ! -d "${wt}" ]] || continue
        n=$((n + 1))
        if [[ -n "${dry}" ]]; then
            echo "would remove ${name} (worktree gone: ${wt})"
        else
            podman pod rm --force --time 2 "${name}" >/dev/null 2>&1
            podman volume rm "${name}-pgdata" >/dev/null 2>&1
            ok "removed orphan ${name} (worktree gone: ${wt})"
        fi
    done
    [[ ${n} -gt 0 ]] || echo "no orphaned coats"
}

function cmd_down {
    local pod purge=
    [[ "${1:-}" == "--purge" ]] && purge=1
    pod=$(coat_name) || exit 1
    if ! podman pod exists "${pod}" 2>/dev/null; then
        warn "no coat for ${pod}"
        return 0
    fi
    # --time 2: don't wait the default 10s for postgres to shut down cleanly,
    # it's a throwaway dev db.
    podman pod rm --force --time 2 "${pod}" >/dev/null || die "failed to remove coat ${pod}"
    if [[ -n "${purge}" ]]; then
        if podman volume rm "${pod}-pgdata" >/dev/null 2>&1; then
            ok "coat ${pod} removed (db volume purged)"
        else
            ok "coat ${pod} removed (no db volume to purge)"
        fi
    else
        ok "coat ${pod} removed (db volume ${pod}-pgdata kept)"
    fi
    hint "${PROG} up (recreate)  |  remove the worktree, then ${PROG} gc"
}

# Operational commands need the container + namespace tooling; help/no-arg don't.
function need_tools {
    command -v podman >/dev/null 2>&1 || die "podman is required but not found"
    command -v nsenter >/dev/null 2>&1 || die "nsenter is required but not found"
}

# Leading global flags, any order, before the subcommand:
#   -C <dir>       act as if run from <dir> (target a coat from anywhere)
#   --name <name>  name the coat explicitly when branch heuristics can't apply
while [[ $# -gt 0 ]]; do
    case "${1}" in
    -C)
        [[ -n "${2:-}" ]] || die "-C requires a directory argument"
        cd "${2}" || die "cannot cd to ${2}"
        shift 2
        ;;
    --name)
        [[ -n "${2:-}" ]] || die "--name requires a name argument"
        COAT_OVERRIDE="${2}"
        shift 2
        ;;
    *) break ;;
    esac
done

case "${1:-}" in
help | -h | --help) usage 0 ;;
"") cmd_suggest ;;
up | enter | run | pid | db | status | ls | gc | down)
    need_tools
    sub="${1}"
    shift
    "cmd_${sub}" "$@"
    ;;
*) die "unknown command: ${1} (try: ${PROG} help)" ;;
esac

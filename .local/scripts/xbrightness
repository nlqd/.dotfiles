#!/usr/bin/env bash

# Cache to avoid xrandr on every read. xrandr on the NVIDIA proprietary
# driver triggers a full connector re-probe + ~25 lines of EDID log spam,
# so a status-bar polling this rapidly fills /var/log/syslog.

CACHE="${XDG_RUNTIME_DIR:-/tmp}/xbrightness.cache"

read_via_xrandr() {
  xrandr --verbose 2>/dev/null \
    | rg ' connected' -A5 \
    | rg 'Brightness' \
    | awk '{print $2; exit}'
}

get_monitor() {
  xrandr 2>/dev/null | rg ' connected' | awk '{print $1; exit}'
}

current=$(cat "$CACHE" 2>/dev/null)
if [[ -z $current ]]; then
  current=$(read_via_xrandr)
  [[ -n $current ]] && echo "$current" >"$CACHE"
fi

step="$*"
if [[ -z $step ]]; then
  echo "$current"
  exit 0
fi

new=$(echo "$current $step" | bc)
(($(echo "$new > 1" | bc -l))) && new=1
(($(echo "$new < 0.25" | bc -l))) && new=0.25

monitor=$(get_monitor)
xrandr --output "$monitor" --brightness "$new"
echo "$new" >"$CACHE"
echo "$new"

bindkey -v
export KEYTIMEOUT=1

export XDG_CONFIG_HOME="$HOME/.config"
export XDG_DATA_HOME="$HOME/.local/share"

export DOTNET_ROOT="$HOME/.dotnet"

fpath+=(~/.config/hcloud/completion/zsh)
autoload -Uz compinit; compinit

PATH="/opt/nvim-linux64/bin:$PATH"
PATH="/usr/local/go/bin:$PATH"
PATH="$HOME/go/bin:$PATH"
PATH="$HOME/.local/bin:$PATH"
PATH="$HOME/.local/scripts:$PATH"
PATH="${ASDF_DATA_DIR:-$HOME/.asdf}/shims:$PATH"
PATH="$DOTNET_ROOT:$DOTNET_ROOT/tools:$PATH"
PATH="$HOME/.TinyTeX/bin/x86_64-linux/:$PATH"
export PATH
export EDITOR=nvim
export MANPAGER='nvim +Man!'
export FZF_DEFAULT_OPTS="--layout=reverse"
export FZF_TMUX_OPTS='-p80%,60%'
export ZSH="$HOME/.oh-my-zsh"

export FLYCTL_INSTALL="/home/qd/.fly"
export PATH="$FLYCTL_INSTALL/bin:$PATH"

alias v='nvim'
alias vg='nvim +G'
alias lmk='latexmk'
alias nb='newsboat -r'
alias nr='newsraft'
alias upgrade='sudo apt update && sudo apt upgrade && flatpak update -y'
alias ez='nvim ~/.zshrc'
alias sz='. ~/.zshrc'
alias ck='nvim ~/.sdai/cookies'
alias tma='tmux -2 a'
alias lg='lazygit'
alias ldk='lazydocker'
alias dbui='nvim -c "DBUI"'

alias duchs='du -chs -- * | sort -h'

y() {
  local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
  yazi "$@" --cwd-file="$tmp"
  if cwd="$(command cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
    builtin cd -- "$cwd"
  fi
  rm -f -- "$tmp"
}

